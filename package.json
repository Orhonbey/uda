{
  "name": "uda-cli",
  "version": "0.2.1",
  "description": "Universal Dev AI — AI-agnostic context engineering + RAG for game development",
  "type": "module",
  "main": "./src/cli.js",
  "bin": {
    "uda-cli": "./bin/uda.js",
    "uda": "./bin/uda.js"
  },
  "files": [
    "bin/",
    "src/",
    "!src/**/*.test.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test --test-concurrency=1 src/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage src/**/*.test.js",
    "dev": "node bin/uda.js",
    "preversion": "npm test",
    "postversion": "git push origin main --follow-tags"
  },
  "keywords": [
    "ai",
    "context-engineering",
    "rag",
    "game-dev",
    "unity",
    "godot",
    "unreal",
    "cli",
    "vector-database",
    "embeddings"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Orhonbey/uda"
  },
  "author": "UDA Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@xenova/transformers": "^2.17.2",
    "commander": "^14.0.3",
    "simple-git": "^3.32.3",
    "yaml": "^2.8.2"
  }
}
